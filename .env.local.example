# Get these from sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Only needed for running migration scripts (not for local dev or production)
SANITY_WRITE_TOKEN=your_write_token_here

# Google Analytics 4 — get from analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
